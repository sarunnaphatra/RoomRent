[
  {
    "id": "TC001",
    "title": "Validation error when check-out date is the same as or before check-in date",
    "description": "Verifies that the UI prevents booking submission when the check-out date is not after the check-in date and shows the correct validation message.",
    "category": "Room Booking",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Click on a room to view details"
      },
      {
        "type": "assertion",
        "description": "Verify text \"availability\" is visible"
      },
      {
        "type": "action",
        "description": "Click on the check-in date field"
      },
      {
        "type": "action",
        "description": "Select a check-in date from the calendar"
      },
      {
        "type": "action",
        "description": "Click on the check-out date field"
      },
      {
        "type": "action",
        "description": "Select a check-out date that is the same as the check-in date or earlier from the calendar"
      },
      {
        "type": "action",
        "description": "Click on \"Submit booking request\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Check-out date must be after check-in date\" is visible"
      }
    ]
  },
